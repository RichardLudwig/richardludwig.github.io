</span><span class="n">btn_1</span> <span class="o">=</span> <span class="n">calc_btn</span><span class="p">(</span><span class="n">root</span><span class="p">,</span> <span class="s">"1"</span><span class="p">,</span> <span class="k">lambda</span><span class="p">:</span> <span class="n">user_input</span><span class="p">(</span><span class="mi">1</span><span class="p">),</span> <span class="n">btn_height</span><span class="p">,</span> <span class="n">btn_width</span><span class="p">,</span> <span class="n">font</span><span class="p">,</span> <span class="n">font_size</span><span class="p">,</span> <span class="mi">4</span><span class="p">,</span> <span class="mi">0</span><span class="p">)</span>
<span class="c1"># 2 btn
</span><span class="n">btn_2</span> <span class="o">=</span> <span class="n">calc_btn</span><span class="p">(</span><span class="n">root</span><span class="p">,</span> <span class="s">"2"</span><span class="p">,</span> <span class="k">lambda</span><span class="p">:</span> <span class="n">user_input</span><span class="p">(</span><span class="mi">2</span><span class="p">),</span> <span class="n">btn_height</span><span class="p">,</span> <span class="n">btn_width</span><span class="p">,</span> <span class="n">font</span><span class="p">,</span> <span class="n">font_size</span><span class="p">,</span> <span class="mi">4</span><span class="p">,</span> <span class="mi">1</span><span class="p">)</span>
<span class="c1"># 3 btn
</span><span class="n">btn_3</span> <span class="o">=</span> <span class="n">calc_btn</span><span class="p">(</span><span class="n">root</span><span class="p">,</span> <span class="s">"3"</span><span class="p">,</span> <span class="k">lambda</span><span class="p">:</span> <span class="n">user_input</span><span class="p">(</span><span class="mi">3</span><span class="p">),</span> <span class="n">btn_height</span><span class="p">,</span> <span class="n">btn_width</span><span class="p">,</span> <span class="n">font</span><span class="p">,</span> <span class="n">font_size</span><span class="p">,</span> <span class="mi">4</span><span class="p">,</span> <span class="mi">2</span><span class="p">)</span>
<span class="c1"># Subtraction btn
</span><span class="n">btn_subtraction</span> <span class="o">=</span> <span class="n">calc_btn</span><span class="p">(</span><span class="n">root</span><span class="p">,</span> <span class="s">"-"</span><span class="p">,</span> <span class="k">lambda</span><span class="p">:</span> <span class="n">user_input</span><span class="p">(</span><span class="s">"-"</span><span class="p">),</span> <span class="n">btn_height</span><span class="p">,</span> <span class="n">btn_width</span><span class="p">,</span> <span class="n">font</span><span class="p">,</span> <span class="n">font_size</span><span class="p">,</span> <span class="mi">4</span><span class="p">,</span> <span class="mi">3</span><span class="p">)</span>
</code></pre></div></div>
<p><br />
<br />
Create the fifth row of buttons.</p>
<div class="language-python highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c1"># ROW 5
